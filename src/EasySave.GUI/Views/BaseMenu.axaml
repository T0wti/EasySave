<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:EasySave.GUI.ViewModels"
        x:Class="EasySave.GUI.Views.BaseMenu"
        x:DataType="viewModels:BaseMenuViewModel">

    <StackPanel Spacing="20" Margin="40" HorizontalAlignment="Center" VerticalAlignment="Center">
        
        <Image Source="/Assets/easysave-logo.png" Height="250"/>

        <TextBlock Text="{Binding Welcome}" 
                    FontSize="24" FontWeight="Bold"
                    Foreground="{StaticResource TextSecondary}"
                    HorizontalAlignment="Center"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    MaxWidth="250"/>

        <Border Background="{StaticResource CardBackground}" 
                CornerRadius="8" 
                Padding="10" 
                Margin="10"
                BoxShadow="0 4 15 0 #10000000"
                MinWidth="200">
            <Panel>
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ConfiguredBackupStr}" 
                                FontSize="16" 
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondary}" 
                                HorizontalAlignment="Center" IsVisible="{Binding !NoBackups}"/>
                
                    <TextBlock Text="{Binding BackupNumber}" 
                                FontSize="48" 
                                FontWeight="Bold" 
                                Foreground="{StaticResource TextPrimary}" 
                                HorizontalAlignment="Center" IsVisible="{Binding !NoBackups}"/>
                </StackPanel>

                <!-- Create save button -->
                <Button Classes="MenuBtn" Command="{Binding NavigateToCreateBackupCommand}" IsVisible="{Binding NoBackups}">
                    <StackPanel Orientation="Horizontal">
                        <PathIcon Grid.Column="0" Classes="MenuIcon"
                                    Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"/>
                        <TextBlock Grid.Column="1" Text="{Binding CreateBackup}"/>
                    </StackPanel>
                </Button>
            </Panel>
        </Border>
        <Border Background="#EBF4FF" 
                BorderBrush="{StaticResource AccentColor}" 
                BorderThickness="1"
                CornerRadius="8" 
                Padding="10" 
                Margin="10"
                BoxShadow="0 4 15 0 #05000000"
                MinWidth="200">
            <Grid ColumnDefinitions="Auto, *">
                <TextBlock Grid.Column="0" Text="💡" FontSize="32" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="5">
                    <TextBlock Text="{Binding HomeTipTitle}" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
                    <TextBlock Text="{Binding HomeRandomTip}"
                                FontStyle="Italic" 
                                TextWrapping="WrapWithOverflow" 
                                Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>

</UserControl>