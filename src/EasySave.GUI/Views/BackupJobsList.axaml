<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dto="using:EasySave.Application.DTOs"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:EasySave.GUI.Views"
             mc:Ignorable="d"
             x:Class="EasySave.GUI.Views.BackupJobsList"
             x:Name="This">
        <UserControl.Resources>
        <converters:BackupTypeConverter x:Key="BackupTypeConverter"
                                        Texts="{Binding Path=Texts, ElementName=This}"/>
    </UserControl.Resources>

    <StackPanel Spacing="10">
    
        <ListBox ItemsSource="{Binding #This.Jobs}"
                 SelectedItem="{Binding #This.SelectedJob, Mode=TwoWay}"
                 Background="Transparent"
                 Name="JobsListBox">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="CornerRadius" Value="10"/>
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="Padding" Value="5"/>
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="#16416c"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="dto:BackupJobDTO">
                    <Border Padding="10"
                            Background="#F0F0F0"
                            CornerRadius="5"
                            Margin="0,2">

                        <StackPanel Orientation="Vertical">

                            <!-- Name -->
                            <TextBlock Text="{Binding Name}" Classes="PrimaryText"/>

                            <!-- Source -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding  #This.Texts.BackupSourcePathTitle, ElementName=This}"></TextBlock>
                                <TextBlock Text="{Binding SourcePath}" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <!-- Target -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding #This.Texts.BackupTargetPathTitle, ElementName=This}"></TextBlock>
                                <TextBlock Text="{Binding TargetPath}" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <!-- Type -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding  #This.Texts.BackupTypeTitle, ElementName=This}"></TextBlock>
                                <TextBlock Text="{Binding Type, Converter={StaticResource BackupTypeConverter}}"
                                           Foreground="{StaticResource TextSecondary}"/>                            </StackPanel>

                        </StackPanel>

                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</UserControl>